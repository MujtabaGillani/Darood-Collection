# Copy to .env and edit. `docker compose` reads these for ${VAR} substitution.

# Secret key. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-please-set-a-real-secret

# Never run production with DEBUG on.
DJANGO_DEBUG=False

# Comma-separated hostnames/IPs that may serve the app (use your domain).
DJANGO_ALLOWED_HOSTS=*

# Comma-separated https origins trusted for POST/CSRF,
# e.g. https://darood.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# Set True once you serve over HTTPS (adds secure cookies, HSTS, SSL redirect).
# Requires TLS terminated by a proxy that sets X-Forwarded-Proto.
DJANGO_SECURE_SSL=False

# Host port to expose the app on (container always listens on 8000).
HOST_PORT=8000

# Set to true to load demo users + sample data on first start.
SEED_DEMO=false

# Gunicorn worker processes (rule of thumb: 2 * CPU cores + 1).
WEB_CONCURRENCY=3
