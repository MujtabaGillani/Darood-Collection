msgstr "درود کلیکشن · اللہ ہمارے درود قبول فرمائے۔"

# --- Login ---
msgid "Login"
msgstr "لاگ اِن"

msgid "Sign in to continue"
msgstr "جاری رکھنے کے لیے سائن اِن کریں"

